# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit the real .env to version control.
# ============================================================

# --- Database ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=splitwise_db
DB_USER=root
DB_PASSWORD=your_mysql_password_here

# --- JWT ---
# Use a long, random string in production (e.g. openssl rand -hex 64)
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# --- Server ---
PORT=5000
NODE_ENV=development

# --- Frontend (for CORS allow-list) ---
CLIENT_URL=http://localhost:5173

# --- Currency ---
# USD → INR exchange rate used for all foreign currency expenses.
# Scope decision: this is a fixed config value, not a live rate feed.
# See DECISIONS.md for rationale.
EXCHANGE_RATE_USD_TO_INR=83
